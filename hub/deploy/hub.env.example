# Copy to ~/remind-me-hub/hub.env and fill in real values (chmod 600).
# The password must match postgres.env; the host is the Postgres container's
# DNS name on the remind-me network.
DATABASE_URL=postgresql://remindme:change-me@remind-me-postgres:5432/remindme

# Shared bearer token — must match REMIND_ME_SYNC_SECRET on every client.
SYNC_SECRET=change-me
